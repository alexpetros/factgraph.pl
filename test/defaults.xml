<?xml version="1.0"?>
<?xml-model href="./FactDictionaryModule.rng"?>
<FactDictionaryModule>
  <Facts>
    <Fact path="/input">
      <Override>
        <Condition>
          <Dependency path="/override"/>
        </Condition>
        <Default>
          <Int>100</Int>
        </Default>
      </Override>
      <Writable>
        <Int/>
      </Writable>
      <Placeholder>
        <Int>0</Int>
      </Placeholder>
    </Fact>
    <Fact path="/override">
      <Writable>
        <Boolean/>
      </Writable>
    </Fact>
  </Facts>
</FactDictionaryModule>


